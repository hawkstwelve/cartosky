CARTOSKY_V3_DATA_ROOT=/opt/cartosky/data/v3
CARTOSKY_V3_LOOP_URL_PREFIX=/loop/v3
CARTOSKY_V3_WORKERS=4
CARTOSKY_V3_SCHEDULER_VARS=tmp2m,tmp850,precip_total,snowfall_total,wspd10m,refc,radar_ptype
CARTOSKY_V3_SCHEDULER_PRIMARY_VARS=tmp2m
CARTOSKY_V3_SCHEDULER_POLL_SECONDS=300
CARTOSKY_V3_SCHEDULER_KEEP_RUNS=2
CARTOSKY_V3_SCHEDULER_PROBE_VAR=tmp2m

# Loop WebP pre-generation (post-publish)
CARTOSKY_V3_LOOP_PREGENERATE_ENABLED=1
CARTOSKY_V3_LOOP_CACHE_ROOT=/opt/cartosky/data/v3/loop_cache
CARTOSKY_V3_LOOP_PREGENERATE_WORKERS=4
CARTOSKY_V3_LOOP_WEBP_QUALITY=82
CARTOSKY_V3_LOOP_WEBP_MAX_DIM=1600
CARTOSKY_V3_LOOP_WEBP_TIER1_MAX_DIM=2400
CARTOSKY_V3_LOOP_WEBP_TIER1_QUALITY=86

# Herbie subset fetch controls (still subset-only, no full-file fallback)
CARTOSKY_HERBIE_PRIORITY=aws,nomads,google,azure,pando,pando2
TWF_HERBIE_SUBSET_RETRIES=2
TWF_HERBIE_RETRY_SLEEP_SECONDS=0.6
CARTOSKY_HERBIE_SAVE_DIR=/opt/cartosky/herbie_cache

# CartoSky forums OAuth and REST API settings
CARTOSKY_FORUMS_BASE=https://theweatherforums.com
CARTOSKY_FORUMS_CLIENT_ID=<client id here>
CARTOSKY_FORUMS_CLIENT_SECRET=<secret here>
CARTOSKY_FORUMS_REDIRECT_URI=https://api.cartosky.com/auth/twf/callback
CARTOSKY_FORUMS_FORUMS_ENDPOINT=https://theweatherforums.com/api/index.php?/forums/forums
CARTOSKY_FORUMS_TOPICS_ENDPOINT=https://theweatherforums.com/api/index.php?/forums/topics
CARTOSKY_FORUMS_SCOPES="profile forums_posts"
FRONTEND_RETURN=https://cartosky.com
SESSION_COOKIE_NAME=cartosky_session
OAUTH_COOKIE_NAME=cartosky_forums_oauth
TOKEN_DB_PATH=/var/lib/cartosky/oauth_tokens.sqlite3
TOKEN_ENC_KEY=<enc key here>
CARTOSKY_FORUMS_API_KEY=<api key here>
CORS_ORIGINS=https://cartosky.com

# Admin telemetry + dashboard
CARTOSKY_TELEMETRY_DB_PATH=/var/lib/cartosky/admin_telemetry.sqlite3
CARTOSKY_ADMIN_MEMBER_IDS=12345
