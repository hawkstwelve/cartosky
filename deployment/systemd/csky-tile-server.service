[Unit]
Description=CartoSky Tile Server
After=network.target

[Service]
Type=simple
User=cartosky
Group=cartosky
UMask=0027
WorkingDirectory=/opt/cartosky
EnvironmentFile=-/etc/cartosky/tile-server.env
Environment=PATH=/opt/cartosky/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/opt/cartosky/.venv/bin/uvicorn backend.app.services.tile_server:app --host 127.0.0.1 --port 8201 --workers 3
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target