CARTOSKY_V3_DATA_ROOT=/opt/cartosky/data/v3
CARTOSKY_V3_WORKERS=6
CARTOSKY_V3_SCHEDULER_VARS=tmp2m,tmp850,dp2m,precip_total,snowfall_total,snowfall_kuchera_total,wspd10m,wgst10m,refc,radar_ptype
CARTOSKY_V3_SCHEDULER_PRIMARY_VARS=tmp2m
CARTOSKY_V3_SCHEDULER_POLL_SECONDS=300
CARTOSKY_V3_SCHEDULER_KEEP_RUNS=4
CARTOSKY_V3_SCHEDULER_PROBE_VAR=tmp2m
CARTOSKY_V3_DERIVE_BUNDLE=1
TWF_V3_DISK_CACHE_LOCK=1

# Loop WebP pre-generation (post-publish)
CARTOSKY_V3_LOOP_PREGENERATE_ENABLED=1
CARTOSKY_V3_LOOP_CACHE_ROOT=/opt/cartosky/data/v3/loop_cache
CARTOSKY_V3_LOOP_PREGENERATE_WORKERS=4
CARTOSKY_V3_LOOP_WEBP_QUALITY=82
CARTOSKY_V3_LOOP_WEBP_MAX_DIM=1600
CARTOSKY_V3_LOOP_WEBP_TIER1_MAX_DIM=2400
CARTOSKY_V3_LOOP_WEBP_TIER1_QUALITY=86

# Herbie subset fetch controls (still subset-only, no full-file fallback)
CARTOSKY_HERBIE_PRIORITY=aws,nomads,google
TWF_HERBIE_SUBSET_RETRIES=2
TWF_HERBIE_RETRY_SLEEP_SECONDS=1.0
CARTOSKY_HERBIE_SAVE_DIR=/opt/cartosky/herbie_cache