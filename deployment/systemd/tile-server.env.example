# Copy to: /etc/cartosky/tile-server.env
CARTOSKY_V3_DATA_ROOT=/opt/cartosky/data/v3

# Canonical boundaries/hydro vector tileset for /tiles/v3/boundaries/v1/*
CARTOSKY_V3_BOUNDARIES_MBTILES=/opt/cartosky/data/v3/boundaries/v1/cartosky_boundaries.mbtiles
CARTOSKY_V3_BOUNDARIES_TILESET_ID=cartosky-boundaries-v1
CARTOSKY_V3_BOUNDARIES_TILESET_NAME=CartoSky Boundaries v1
CARTOSKY_V3_TILES_PUBLIC_BASE_URL=https://api.cartosky.com
